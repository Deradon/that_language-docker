#!/usr/bin/env bash
#
# Smoke-test a built image against a container it starts itself.
#
#   bin/smoke [image] [port]
#
# Runs the same checks locally that CI runs, so a failure can be reproduced
# without pushing. Every assertion below has already cost debugging time once;
# the comment above each says which trap it guards.
#
# SMOKE_DOCKER_RUN_OPTS passes extra flags to the `docker run` below. Some hosts
# cannot start a container under the default settings and the checks are worth
# running there anyway -- a Docker-in-LXC host on a pre-5.x kernel needs
# --security-opt systempaths=unconfined, because runc cannot mask /proc/acpi.
# Unset everywhere else, so CI and local runs are unaffected.

set -euo pipefail

IMAGE="${1:-that_language-service:ci}"
PORT="${2:-4567}"
BASE="http://localhost:${PORT}"
CONTAINER=""

failures=0

pass() { printf '  ok    %s\n' "$1"; }
fail() { printf '  FAIL  %s\n' "$1"; failures=$((failures + 1)); }

cleanup() {
  if [ -n "${CONTAINER}" ]; then
    docker rm --force "${CONTAINER}" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

# --- 1. Gemfile.lock: both core gems must come from rubygems, not git --------
#
# This check used to assert the exact opposite. Until that_language 0.2.0 was
# published, the Gemfile had to name both gems from git: the service's gemspec
# pinned `that_language ~> 0.1`, which resolved to the broken published 0.1.2 --
# a clean build that died at the first request. Both are on rubygems now, and a
# git source reappearing here would mean someone reintroduced that workaround.
#
# Entries resolved from rubygems carry a sha256= in the CHECKSUMS block;
# git-sourced ones do not. that_language is checked even though only the service
# is declared in the Gemfile -- it must arrive transitively via the gemspec.
echo "Gemfile.lock"
for gem in that_language that_language-service; do
  line="$(grep -E "^  ${gem} \(" Gemfile.lock || true)"
  if [ -z "${line}" ]; then
    fail "${gem} is absent from Gemfile.lock CHECKSUMS"
  elif printf '%s' "${line}" | grep -q 'sha256='; then
    pass "${gem} resolves from rubygems"
  else
    fail "${gem} is git-sourced (the 0.1.2 workaround is back)"
  fi
done

# --- 2. Boot the container --------------------------------------------------
echo "container"
# Unquoted on purpose: SMOKE_DOCKER_RUN_OPTS is a list of flags, not one word.
# shellcheck disable=SC2086
CONTAINER="$(docker run -d ${SMOKE_DOCKER_RUN_OPTS:-} -p "${PORT}:4567" "${IMAGE}")"

for _ in $(seq 1 60); do
  if curl -fsS -o /dev/null "${BASE}/version" 2>/dev/null; then break; fi
  if [ -z "$(docker ps -q --filter "id=${CONTAINER}")" ]; then
    echo "container exited during boot:" >&2
    docker logs "${CONTAINER}" >&2
    exit 1
  fi
  sleep 1
done

if ! curl -fsS -o /dev/null "${BASE}/version"; then
  echo "container never answered on ${BASE}/version:" >&2
  docker logs "${CONTAINER}" >&2
  exit 1
fi
pass "answers on ${BASE}/version"

# --- 3. The eight endpoints, over GET and POST ------------------------------
#
# The endpoint list is a three-repository contract shared with that_language
# and that_language-client. Changing it here is a change in three repos.
echo "endpoints"
TEXT="Guten Tag mein Freund"

check_status() {
  local label="$1" expected="$2"
  shift 2
  local got
  got="$(curl -s -o /dev/null -w '%{http_code}' "$@")"
  if [ "${got}" = "${expected}" ]; then
    pass "${label} -> ${got}"
  else
    fail "${label} -> ${got}, expected ${expected}"
  fi
}

for path in language language_code detect details; do
  check_status "GET  /${path}" 200 --get --data-urlencode "text=${TEXT}" "${BASE}/${path}"
  check_status "POST /${path}" 200 --data-urlencode "text=${TEXT}" "${BASE}/${path}"
done

for path in available available_languages available_language_codes version; do
  check_status "GET  /${path}" 200 "${BASE}/${path}"
  check_status "POST /${path}" 200 -X POST "${BASE}/${path}"
done

# Detection has to actually work, not just answer 200.
detected="$(curl -s --get --data-urlencode "text=${TEXT}" "${BASE}/language")"
if printf '%s' "${detected}" | grep -q 'German'; then
  pass "German detected"
else
  fail "German not detected, got: ${detected}"
fi

# --- 4. A non-localhost Host header is accepted -----------------------------
#
# Sinatra 4's Rack::Protection::HostAuthorization allow-lists localhost only in
# the development environment, so a development container answers
# 403 Host not permitted to everything arriving through a proxy or a domain
# name. This is the regression test for APP_ENV=production being pinned.
echo "host authorization"
check_status "Host: that-language.example.com" 200 \
  -H "Host: that-language.example.com" "${BASE}/version"

# --- 5. The cache is warm before the port is open ---------------------------
#
# Wordlists load lazily and memoise at module level (~0.9 s cold). config.ru
# pays that at boot, before `run`, so the first request does not. Nothing else
# would catch that warm-up silently regressing -- the container would still
# pass every check above, just slower on request one.
echo "boot order"
log="$(docker logs "${CONTAINER}" 2>&1)"
warm="$(printf '%s\n' "${log}" | grep -n 'Cache warm' | head -1 | cut -d: -f1)"
listening="$(printf '%s\n' "${log}" | grep -n 'Listening on' | head -1 | cut -d: -f1)"

if [ -z "${warm}" ]; then
  fail "no 'Cache warm' line in the container log"
elif [ -z "${listening}" ]; then
  fail "no 'Listening on' line in the container log"
elif [ "${warm}" -lt "${listening}" ]; then
  pass "'Cache warm' (line ${warm}) precedes 'Listening on' (line ${listening})"
else
  fail "'Cache warm' (line ${warm}) does not precede 'Listening on' (line ${listening})"
fi

# --- Result -----------------------------------------------------------------
echo
if [ "${failures}" -eq 0 ]; then
  echo "all checks passed"
else
  echo "${failures} check(s) failed"
  docker logs "${CONTAINER}" 2>&1 | tail -40 >&2
  exit 1
fi
